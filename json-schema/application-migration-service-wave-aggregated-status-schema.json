{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://api-evangelist.github.io/amazon-application-migration-service/json-schema/application-migration-service-wave-aggregated-status-schema.json",
  "title": "WaveAggregatedStatus",
  "description": "Aggregated status of all applications in a wave",
  "type": "object",
  "properties": {
    "lastUpdateDateTime": {
      "type": "string",
      "description": "Date/time of last status update"
    },
    "healthStatus": {
      "type": "string",
      "description": "Overall health status"
    },
    "progressStatus": {
      "type": "string",
      "description": "Overall progress status"
    },
    "totalApplications": {
      "type": "integer",
      "description": "Total number of applications in the wave"
    }
  }
}