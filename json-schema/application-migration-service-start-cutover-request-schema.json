{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://api-evangelist.github.io/amazon-application-migration-service/json-schema/application-migration-service-start-cutover-request-schema.json",
  "title": "StartCutoverRequest",
  "description": "Request to start a cutover migration job",
  "type": "object",
  "properties": {
    "sourceServerIDs": {
      "type": "array",
      "description": "Source server IDs to cut over"
    },
    "tags": {
      "type": "object",
      "description": "Tags for the cutover job"
    },
    "accountID": {
      "type": "string",
      "description": "Account ID for cross-account access"
    }
  }
}